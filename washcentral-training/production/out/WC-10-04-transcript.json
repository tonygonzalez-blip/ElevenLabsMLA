      "endS": 149.402,
      "timing": "proportional"
    },
    {
      "block": "s08",
      "id": "p46",
      "text": "The last row already resolved, a network failover note.",
      "startS": 149.402,
      "endS": 153.418,
      "timing": "proportional"
    },
    {
      "block": "s08",
      "id": "p47",
      "text": "Three rows still active.",
      "startS": 153.418,
      "endS": 155.387,
      "timing": "proportional"
    },
    {
      "block": "s08",
      "id": "p48",
      "text": "That is the Active Alerts tile, itemized.",
      "startS": 155.387,
      "endS": 158.683,
