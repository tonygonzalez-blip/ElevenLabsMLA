      "endS": 114.274,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p38",
      "text": "New Record and Export act on the shared tenant, and a support read never creates an alert.",
      "startS": 114.58,
      "endS": 115.302,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p39",
      "text": "The pager below counts four rows.",
      "startS": 115.693,
      "endS": 130.621,
      "timing": "silence"
    },
    {
      "block": "s08",
      "id": "p40",
      "text": "Now the rows, top to bottom.",
      "startS": 131.04,
      "endS": 134,
      "timing": "proportional"
    },
    {
      "block": "s08",
      "id": "p41",
      "text": "The critical one is a tunnel alert at M-L-A-S,",
      "startS": 134,
      "endS": 137.356,
