      "startS": 153.36,
      "endS": 157.733,
      "timing": "proportional"
    },
    {
      "block": "s10",
      "id": "p50",
      "text": "Under the standings, Quick Links.",
      "startS": 158.16,
      "endS": 159.738,
      "timing": "proportional"
    },
    {
      "block": "s10",
      "id": "p51",
      "text": "A couple of shortcuts, your learning paths and your certificates,",
