      "endS": 60.957,
      "timing": "proportional"
    },
    {
      "block": "s04",
      "id": "p20",
      "text": "so you pick up mid-lesson instead of hunting for where you left off.",
      "startS": 60.957,
      "endS": 65.505,
      "timing": "proportional"
    },
    {
      "block": "s04",
      "id": "p21",
      "text": "On a fresh account it previews the starter course instead,",
