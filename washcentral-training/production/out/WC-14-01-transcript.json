    },
    {
      "block": "s10",
      "id": "p54",
      "text": "Just the fast lane.",
      "startS": 168.498,
      "endS": 169.76,
      "timing": "proportional"
    },
    {
      "block": "s11",
      "id": "p55",
      "text": "Back to the sidebar for the other three stops.",
      "startS": 170.16,
      "endS": 172.519,
      "timing": "silence"
    },
    {
