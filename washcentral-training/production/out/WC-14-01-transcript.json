      "startS": 202.506,
      "endS": 209.688,
      "timing": "silence"
    },
    {
      "block": "s12",
      "id": "p67",
      "text": "Taking a course comes later.",
      "startS": 210.039,
      "endS": 211.6,
      "timing": "silence"
    },
    {
      "block": "s13",
      "id": "p68",
      "text": "That is the learner side.",
      "startS": 212,
      "endS": 213.427,
      "timing": "silence"
    },
    {
