      "endS": 126.778,
      "timing": "silence"
    },
    {
      "block": "s08",
      "id": "p39",
      "text": "Now My Achievements.",
      "startS": 127.2,
      "endS": 128.479,
      "timing": "silence"
    },
    {
      "block": "s08",
      "id": "p40",
      "text": "Three badges earned, three locked.",
      "startS": 129.137,
      "endS": 130.243,
      "timing": "silence"
    },
    {
      "block": "s08",
      "id": "p41",
      "text": "The earned ones render in full color;",
