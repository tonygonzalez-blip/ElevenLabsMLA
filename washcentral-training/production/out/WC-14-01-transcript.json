      "endS": 118.686,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p36",
      "text": "and climb to a two hour fifteen minute analytics course.",
      "startS": 119.155,
      "endS": 121.512,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p37",
      "text": "Real instructors, real lesson counts.",
      "startS": 121.801,
      "endS": 123.904,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p38",
      "text": "Every one reads Not started here, and every Start button stays untouched.",
