      "endS": 103.527,
      "timing": "silence"
    },
    {
      "block": "s06",
      "id": "p32",
      "text": "Not started means available; a moving bar means enrolled.",
      "startS": 103.834,
      "endS": 105.46,
      "timing": "silence"
    },
    {
      "block": "s06",
      "id": "p33",
      "text": "Browse Catalog up in the corner reaches the full library.",
      "startS": 106.233,
      "endS": 109.588,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p34",
      "text": "Six courses on this dashboard.",
      "startS": 110,
      "endS": 111.953,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p35",
      "text": "They start with the platform basics at forty five minutes",
