{
  "lesson": "WC-00-03",
  "audioMaster": "training/module00-setup/WC-00-03-full-narration-v1.0.mp3",
  "audioDurationS": 88.686,
  "method": "silencedetect -32dB/0.28s within known block windows; proportional fallback",
  "phrases": [
    {
      "block": "s01",
      "id": "p01",
      "text": "Look to the far right of the header.",
      "startS": 0,
      "endS": 1.535,
      "timing": "silence"
    },
    {
      "block": "s01",
      "id": "p02",
      "text": "Past Search, the location selector, and Ask Shyne, there is a small badge with your initials.",
      "startS": 1.993,
      "endS": 5.552,
      "timing": "silence"
    },
    {
      "block": "s01",
      "id": "p03",
      "text": "That is your account, and it rides along on every page.",
      "startS": 5.851,
      "endS": 11.412,
      "timing": "silence"
    },
    {
      "block": "s02",
      "id": "p04",
      "text": "Click it.",
      "startS": 11.87,
      "endS": 13.597,
      "timing": "proportional"
    },
    {
      "block": "s02",
      "id": "p05",
      "text": "The menu opens with your name and your tenant code right at the top.",
      "startS": 13.597,
      "endS": 17.204,
      "timing": "proportional"
    },
    {
      "block": "s02",
      "id": "p06",
      "text": "Get in the habit of reading that line.",
      "startS": 17.204,
      "endS": 19.265,
      "timing": "proportional"
    },
    {
      "block": "s02",
      "id": "p07",
      "text": "It is the fastest way to confirm which company you are actually signed into.",
      "startS": 19.265,
      "endS": 22.872,
      "timing": "proportional"
    },
    {
      "block": "s03",
      "id": "p08",
      "text": "Now the list.",
      "startS": 23.35,
      "endS": 24.177,
      "timing": "silence"
    },
    {
      "block": "s03",
      "id": "p09",
      "text": "Profile and Preferences hold your personal settings.",
      "startS": 25.643,
      "endS": 28.58,
      "timing": "silence"
    },
    {
      "block": "s03",
      "id": "p10",
      "text": "Notifications and Help Center do what they say.",
      "startS": 29.781,
      "endS": 32.213,
      "timing": "silence"
    },
    {
      "block": "s03",
      "id": "p11",
      "text": "The two you will reach for most are My Training and the Dark Mode switch.",
      "startS": 32.972,
      "endS": 36.831,
      "timing": "silence"
    },
    {
      "block": "s03",
      "id": "p12",
      "text": "One thing to leave alone for now: Logout, at the bottom, ends your session.",
      "startS": 37.984,
      "endS": 42.522,
      "timing": "silence"
    },
    {
      "block": "s04",
      "id": "p13",
      "text": "Flip the Dark Mode toggle.",
      "startS": 43.08,
      "endS": 44.501,
      "timing": "silence"
    },
    {
      "block": "s04",
      "id": "p14",
      "text": "The whole interface drops to a dark theme on the spot.",
      "startS": 45.231,
      "endS": 48.366,
      "timing": "silence"
    },
    {
      "block": "s04",
      "id": "p15",
      "text": "This is a display preference for you alone.",
      "startS": 48.625,
      "endS": 50.767,
      "timing": "silence"
    },
    {
      "block": "s04",
      "id": "p16",
      "text": "It changes nothing in the data and nothing for anyone else.",
      "startS": 51.002,
      "endS": 54.24,
      "timing": "silence"
    },
    {
      "block": "s05",
      "id": "p17",
      "text": "Toggle it back.",
      "startS": 54.79,
      "endS": 55.481,
      "timing": "silence"
    },
    {
      "block": "s05",
      "id": "p18",
      "text": "Light again.",
      "startS": 55.91,
      "endS": 56.666,
      "timing": "silence"
    },
    {
      "block": "s05",
      "id": "p19",
      "text": "Work in whichever theme is easier on your eyes; the switch is always safe to flip mid-shift.",
      "startS": 58.256,
      "endS": 63.41,
      "timing": "silence"
    },
    {
      "block": "s06",
      "id": "p20",
      "text": "Open the menu again and choose My Training.",
      "startS": 64.02,
      "endS": 66.597,
      "timing": "silence"
    },
    {
      "block": "s06",
      "id": "p21",
      "text": "That opens the WashCentral Academy, your learning home for this whole program.",
      "startS": 67.111,
      "endS": 71.406,
      "timing": "silence"
    },
    {
      "block": "s06",
      "id": "p22",
      "text": "Knowing it sits one click away in the account menu saves you hunting for it later.",
      "startS": 71.974,
      "endS": 76.189,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p23",
      "text": "Head back to the Command Center.",
      "startS": 77.01,
      "endS": 78.342,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p24",
      "text": "Same session, right where you left it.",
      "startS": 78.773,
      "endS": 80.748,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p25",
      "text": "From any screen, your initials in the corner are the door to your settings, your training, and, when you really mean it, the way out.",
      "startS": 81.052,
      "endS": 88.221,
      "timing": "silence"
    }
  ]
}