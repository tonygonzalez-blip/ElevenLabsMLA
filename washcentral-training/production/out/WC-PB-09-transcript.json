{
  "lesson": "WC-PB-09",
  "audioMaster": "training/playbooks/WC-PB-09-full-narration-v1.0.mp3",
  "audioDurationS": 167.158,
  "method": "silencedetect -32dB/0.28s within known block windows; proportional fallback",
  "phrases": [
    {
      "block": "s01",
      "id": "p01",
      "text": "Open Reports from the left rail.",
      "startS": 0,
      "endS": 1.959,
      "timing": "silence"
    },
    {
      "block": "s01",
      "id": "p02",
      "text": "Every report a site runs lives in this one hub.",
      "startS": 3.021,
      "endS": 7.663,
      "timing": "silence"
    },
    {
      "block": "s01",
      "id": "p03",
      "text": "A hundred seventy-three in all, five favorites, three on a schedule.",
      "startS": 7.953,
      "endS": 10.044,
      "timing": "silence"
    },
    {
      "block": "s01",
      "id": "p04",
      "text": "Each row carries a type tag and the last time it ran.",
      "startS": 10.785,
      "endS": 13.68,
      "timing": "silence"
    },
    {
      "block": "s02",
      "id": "p05",
      "text": "Name the symptom before you touch a filter.",
      "startS": 14.08,
      "endS": 16.67,
      "timing": "silence"
    },
    {
      "block": "s02",
      "id": "p06",
      "text": "Wrong numbers or an empty report is a filter question.",
      "startS": 17.501,
      "endS": 20.649,
      "timing": "silence"
    },
    {
      "block": "s02",
      "id": "p07",
      "text": "A scheduled report that never landed is a scheduler question.",
      "startS": 21.401,
      "endS": 24.75,
      "timing": "silence"
    },
    {
      "block": "s02",
      "id": "p08",
      "text": "Decide which ticket you have, or you'll re-run the wrong report ten times.",
      "startS": 25.678,
      "endS": 30.427,
      "timing": "silence"
    },
    {
      "block": "s03",
      "id": "p09",
      "text": "Take the wrong-or-empty trail first. Open the report from the list.",
      "startS": 30.88,
      "endS": 33.06,
      "timing": "silence"
    },
    {
      "block": "s03",
      "id": "p10",
      "text": "It loads in the Report Viewer, and the filter bar across the top is the whole story.",
      "startS": 34.096,
      "endS": 35.619,
      "timing": "silence"
    },
    {
      "block": "s03",
      "id": "p11",
      "text": "More filters, a location selector, a date range, and the run control.",
      "startS": 36.011,
      "endS": 45.68,
      "timing": "silence"
    },
    {
      "block": "s04",
      "id": "p12",
      "text": "Now read the scope.",
      "startS": 46.134,
      "endS": 47.194,
      "timing": "silence"
    },
    {
      "block": "s04",
      "id": "p13",
      "text": "Most wrong-numbers tickets die here.",
      "startS": 47.828,
      "endS": 50.068,
      "timing": "silence"
    },
    {
      "block": "s04",
      "id": "p14",
      "text": "The selector sat on one site when the manager meant the network,",
      "startS": 50.634,
      "endS": 53.871,
      "timing": "silence"
    },
    {
      "block": "s04",
      "id": "p15",
      "text": "or the dates missed the week in question.",
      "startS": 54.196,
      "endS": 56.135,
      "timing": "silence"
    },
    {
      "block": "s04",
      "id": "p16",
      "text": "Fix both, run it again, compare.",
      "startS": 56.57,
      "endS": 58.829,
      "timing": "silence"
    },
    {
      "block": "s04",
      "id": "p17",
      "text": "A report is only wrong once its filters are right.",
      "startS": 59.46,
      "endS": 62.091,
      "timing": "silence"
    },
    {
      "block": "s05",
      "id": "p18",
      "text": "One caution before you file anything.",
      "startS": 62.56,
      "endS": 64.66,
      "timing": "silence"
    },
    {
      "block": "s05",
      "id": "p19",
      "text": "In this demo tenant, a KPI tile and the table beneath it often disagree, sometimes wildly.",
      "startS": 65.107,
      "endS": 71.115,
      "timing": "silence"
    },
    {
      "block": "s05",
      "id": "p20",
      "text": "That's a known demo artifact, not a platform bug.",
      "startS": 71.711,
      "endS": 74.32,
      "timing": "silence"
    },
    {
      "block": "s05",
      "id": "p21",
      "text": "Reproduce the numbers in production before you open a ticket.",
      "startS": 74.77,
      "endS": 77.676,
      "timing": "silence"
    },
    {
      "block": "s06",
      "id": "p22",
      "text": "Now the report that never arrived. Open the Scheduled Reports view.",
      "startS": 78.136,
      "endS": 80.262,
      "timing": "silence"
    },
    {
      "block": "s06",
      "id": "p23",
      "text": "Three reports run on a schedule here.",
      "startS": 81.179,
      "endS": 82.996,
      "timing": "silence"
    },
    {
      "block": "s06",
      "id": "p24",
      "text": "Confirm the missing one is actually among them, and read its last run.",
      "startS": 83.641,
      "endS": 85.543,
      "timing": "silence"
    },
    {
      "block": "s06",
      "id": "p25",
      "text": "Not scheduled at all? There's your answer.",
      "startS": 85.872,
      "endS": 92.727,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p26",
      "text": "Cross-check the job that sends it. Settings, then Automation, then Task Scheduler.",
      "startS": 93.2,
      "endS": 94.891,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p27",
      "text": "Eighteen tasks, sixteen active, two running now.",
      "startS": 95.939,
      "endS": 99.638,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p28",
      "text": "And the tile that matters reads failed, zero.",
      "startS": 100.52,
      "endS": 104.064,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p29",
      "text": "Nothing errored overnight.",
      "startS": 104.954,
      "endS": 108.05,
      "timing": "silence"
    },
    {
      "block": "s07",
      "id": "p30",
      "text": "When that count isn't zero, you have your lead.",
      "startS": 108.375,
      "endS": 113.116,
      "timing": "silence"
    },
    {
      "block": "s08",
      "id": "p31",
      "text": "Find the Daily Report Email row.",
      "startS": 113.677,
      "endS": 115.808,
      "timing": "silence"
    },
    {
      "block": "s08",
      "id": "p32",
      "text": "Read across it.",
      "startS": 116.151,
      "endS": 120.817,
      "timing": "silence"
    },
    {
      "block": "s08",
      "id": "p33",
      "text": "Scheduled daily at six. Last ran today at six.",
      "startS": 121.108,
      "endS": 122.91,
      "timing": "silence"
    },
    {
      "block": "s08",
      "id": "p34",
      "text": "Next run, tomorrow at six. Status, active.",
      "startS": 123.16,
      "endS": 124.515,
      "timing": "silence"
    },
    {
      "block": "s08",
      "id": "p35",
      "text": "A missing report usually shows here as a stale last run or a status that isn't active.",
      "startS": 124.867,
      "endS": 130.576,
      "timing": "silence"
    },
    {
      "block": "s08",
      "id": "p36",
      "text": "Read it, never edit it.",
      "startS": 131.073,
      "endS": 132.902,
      "timing": "silence"
    },
    {
      "block": "s09",
      "id": "p37",
      "text": "Now build the ticket.",
      "startS": 133.36,
      "endS": 134.538,
      "timing": "silence"
    },
    {
      "block": "s09",
      "id": "p38",
      "text": "Name the report, the location scope, and the date range you ran it with.",
      "startS": 135.09,
      "endS": 139.112,
      "timing": "silence"
    },
    {
      "block": "s09",
      "id": "p39",
      "text": "For a scheduled report, add the job's last run, next run, and status.",
      "startS": 140.054,
      "endS": 144.647,
      "timing": "silence"
    },
    {
      "block": "s09",
      "id": "p40",
      "text": "Attach a screenshot. Leave the demo-tenant number quirks out of it.",
      "startS": 144.991,
      "endS": 149.04,
      "timing": "silence"
    },
    {
      "block": "s10",
      "id": "p41",
      "text": "That's the playbook.",
      "startS": 149.44,
      "endS": 150.783,
      "timing": "silence"
    },
    {
      "block": "s10",
      "id": "p42",
      "text": "Name the symptom.",
      "startS": 151.118,
      "endS": 152.154,
      "timing": "silence"
    },
    {
      "block": "s10",
      "id": "p43",
      "text": "Wrong or empty means the filter bar.",
      "startS": 152.865,
      "endS": 155.392,
      "timing": "silence"
    },
    {
      "block": "s10",
      "id": "p44",
      "text": "Never arrived means Scheduled Reports and the Task Scheduler.",
      "startS": 155.851,
      "endS": 159.798,
      "timing": "silence"
    },
    {
      "block": "s10",
      "id": "p45",
      "text": "Rule out the demo artifact, escalate with the filters and the run times,",
      "startS": 160.231,
      "endS": 162.189,
      "timing": "silence"
    },
    {
      "block": "s10",
      "id": "p46",
      "text": "and change nothing along the way.",
      "startS": 162.413,
      "endS": 166.696,
      "timing": "silence"
    }
  ]
}