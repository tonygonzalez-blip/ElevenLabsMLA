    { "op": "move", "at": 4.15, "to": { "target": "thLocation", "offset": [0, 0] }, "note": "step 1: 'location, total, status, and tender' (p03) — header sweep in spoken order" },
    { "op": "move", "at": 5.35, "to": { "target": "thTotal", "offset": [0, 0] } },
    { "op": "move", "at": 6.35, "to": { "target": "thStatus", "offset": [0, 0] } },
    { "op": "move", "at": 7.25, "to": { "target": "thTender", "offset": [0, 0] } },
    { "op": "move", "at": 8.85, "to": { "target": "rowStatusCell", "offset": [0, 0] }, "note": "step 1: 'Status is worth a glance on the way in' (p04) — the row's live status value" },
    { "op": "move", "at": 11.45, "to": { "point": [1898, 650] }, "note": "park in the right margin for p05-p06 (filter before you open)" },
    { "op": "move", "at": 19.87, "to": { "target": "ticketRow", "offset": [0, 0] }, "note": "step 2 cue 'Click the row.' (p07) — approach starts at the cue; row center sits in the inert Date/Time area, the whole tr is the row-link" },
    { "op": "click", "target": "ticketRow", "pressAt": 21.05, "hoverMs": 380, "postcondition": "onTicketView", "timeoutMs": 9000, "nav": true, "note": "step 2: GENUINE on-camera row click opens sales-ticket-view.html?ticket=<id> (probe-verified: real mouse click on tr.row-link navigated to ?ticket=1501159); press lands inside p07's trailing break" },
    { "op": "wait-stable", "afterNav": true, "key": "ticketStable", "predicate": "ticketReady", "settleMs": 700, "timeoutMs": 9000 },
    { "op": "assert", "at": 22.55, "predicate": "onTicketView", "note": "the address now carries ?ticket=<id> — page identity for the deep-link talk" },
    { "op": "log-rects", "at": 22.75, "key": "hdr", "targets": ["heroTop", "nameRow", "titleName", "metaLine", "backBtn", "refundBtn", "band", "tile1", "tile2", "tile3", "tile4", "tabNav"] },
    { "op": "move", "at": 23.3, "to": { "target": "metaLine", "offset": [0, 28], "outside": true }, "note": "step 2: settle under the ID line while p08-p11 explain the deep link (address bar itself is browser chrome, outside the page capture — RESIDUAL R1)" },
    { "op": "watch", "key": "mainHold", "from": 23.6, "to": 171.4, "predicate": "mainShown", "everyMs": 600, "mustHold": true, "note": "Main tab must stay active through steps 2-9" },
    { "op": "move", "at": 36.1, "to": { "target": "titleName", "offset": [0, 0] }, "note": "step 3: 'The ticket number is the title' (p13)" },
    { "op": "move", "at": 39.75, "to": { "target": "metaLine", "offset": [-80, 0] }, "note": "step 3: '...with the I-D, the location' (p13) — the meta line beneath" },
    { "op": "move", "at": 44.05, "to": { "target": "metaLine", "offset": [115, 0] }, "note": "step 3: 'That timestamp matters' (p14-p15) — the timestamp end of the line" },
    { "op": "move", "at": 51.6, "to": { "point": [1898, 300] }, "note": "park for p16 (confirm the transaction)" },
    { "op": "move", "at": 57.0, "to": { "target": "backBtn", "offset": [0, 0] }, "note": "step 4: 'Top-right, two buttons' (p17) then 'Back to Tickets takes you home' (p18)" },
    { "op": "move", "at": 60.7, "to": { "target": "refundBtn", "offset": [-8, 42], "outside": true }, "note": "step 4: 'The red one is Refund, and we do not touch it' (p19) — hover NEAR the button, never on it, never clicked (PARKED #5)" },
    { "op": "move", "at": 71.95, "to": { "target": "refundBtn", "offset": [-64, 46], "outside": true }, "note": "step 4: 'Read the button, leave it alone' (p22) — stay clear through the guardrail" },
    { "op": "move", "at": 74.25, "to": { "target": "tile1", "offset": [0, 20] }, "note": "step 5: 'Under the header, four quick figures' (p23)" },
    { "op": "move", "at": 77.9, "to": { "target": "tile2", "offset": [0, 20] }, "note": "step 5: p24 sweep in spoken order — total, payments, status, payment type" },
    { "op": "move", "at": 78.7, "to": { "target": "tile3", "offset": [0, 20] } },
    { "op": "move", "at": 79.5, "to": { "target": "tile4", "offset": [0, 20] } },
    { "op": "move", "at": 81.5, "to": { "target": "band", "offset": [0, 64], "outside": true }, "note": "step 5: 'that band answers the question' (p25) — rest below the band" },
    { "op": "move", "at": 87.1, "to": { "target": "tile1", "offset": [0, 20] }, "note": "step 5: 'a mismatch between total and payments' (p27) — the pair" },
    { "op": "move", "at": 88.3, "to": { "target": "tile2", "offset": [0, 20] } },
