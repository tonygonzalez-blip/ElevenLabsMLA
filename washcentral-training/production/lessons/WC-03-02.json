  "predicates": {
    "onTickets": "location.pathname.endsWith('/sales-transactions.html')",
    "onTicketView": "location.pathname.endsWith('/sales-ticket-view.html')&&/[?&]ticket=\\d+/.test(location.search)",
    "sidebarExpanded": "!!document.querySelector('.app')&&!document.querySelector('.app').classList.contains('sidebar-collapsed')",
    "startReady": "document.readyState==='complete'&&!!document.querySelector('.app')&&!document.querySelector('.app').classList.contains('sidebar-collapsed')&&document.querySelectorAll('aside.sidebar a').length===9&&document.querySelectorAll('.a-metric').length>=4&&!!document.querySelector('table tbody tr.row-link')&&window.scrollY<=8&&![...document.querySelectorAll('[class*=\"skeleton\"],[class*=\"spinner\"],[class*=\"loading\"]')].some(e=>e.getBoundingClientRect().width>0)",
    "ticketReady": "document.readyState==='complete'&&!!document.querySelector('.a-name')&&document.querySelectorAll('.a-tab-btn').length>=5&&document.querySelectorAll('.a-metric').length>=4&&![...document.querySelectorAll('[class*=\"skeleton\"],[class*=\"spinner\"],[class*=\"loading\"]')].some(e=>e.getBoundingClientRect().width>0)",
    "mainShown": "[...document.querySelectorAll('.a-group-hdr')].some(e=>/^Ticket Information$/i.test((e.textContent||'').trim())&&e.getBoundingClientRect().width>0)",
    "refundsShown": "(document.querySelector('.a-tab-btn.active')?.textContent||'').trim()==='Refunds'&&[...document.querySelectorAll('.a-group-hdr')].some(e=>/^Refund History$/i.test((e.textContent||'').trim())&&e.getBoundingClientRect().width>0)",
    "listReady": "document.readyState==='complete'&&document.querySelectorAll('.a-metric').length>=4&&!!document.querySelector('table tbody tr.row-link')&&![...document.querySelectorAll('[class*=\"skeleton\"],[class*=\"spinner\"],[class*=\"loading\"]')].some(e=>e.getBoundingClientRect().width>0)"
  },
  "preflight": [
    {
      "op": "click",
      "target": "expandToggle",
      "pressAt": 0,
      "hoverMs": 220,
      "unless": "sidebarExpanded",
      "postcondition": "sidebarExpanded",
      "timeoutMs": 4000,
      "note": "off-camera: stage the Sales sidebar expanded (persisted pref washcentral-sidebar-collapsed-v5; same control both ways); skipped when already expanded. Probe-verified July 11: one toggle click flips app.sidebar-collapsed and the state persists across the row-click nav and Back to Tickets."
    }
  ],
  "ops": [
    { "op": "assert", "at": -1.5, "predicate": "onTickets", "note": "start page identity before capture" },
    { "op": "assert", "at": -0.9, "predicate": "startReady", "note": "list loaded, sidebar expanded (9 Sales pages), rows present, top of page, no skeletons" },
    { "op": "pointer-enter", "at": 0.45, "from": [2, 880], "to": { "target": "breadcrumb", "offset": [70, 34], "outside": true }, "note": "enter from the left edge, settle under the Transactions crumb during p01" },
    { "op": "log-rect", "at": 1.0, "key": "breadcrumbRect", "target": "breadcrumb", "requireStableMs": 260 },
    { "op": "log-rect", "at": 1.3, "key": "theadRect", "target": "theadRow", "requireStableMs": 240 },
