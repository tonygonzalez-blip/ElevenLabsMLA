      "hoverMs": 200,
      "unless": "servicesGroupOpen",
      "postcondition": "servicesGroupOpen",
      "timeoutMs": 4000,
      "note": "off-camera: expand the Services group on settings home so step 1's 'open Services' is a single genuine click on the Services link"
    }
  ]
