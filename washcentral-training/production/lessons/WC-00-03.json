    "camera": [
      { "t": 0.0, "z": 1.0, "cx": 960, "cy": 540 },
      { "t": 2.0, "z": 1.0, "cx": 960, "cy": 540 },
      { "t": 2.9, "z": 1.4, "cx": 1500, "cy": 165, "ease": true, "note": "restrained top-right punch-in; keeps Search, All Locations, Ask Shyne, avatar in frame" },
      { "t": 13.4, "z": 1.4, "cx": 1500, "cy": 165 },
      { "t": 14.4, "z": 1.55, "cx": 1690, "cy": 235, "ease": true, "note": "close framing on the name + tenant-code header (~1.5s)" },
      { "t": 16.4, "z": 1.55, "cx": 1690, "cy": 235 },
      { "t": 17.4, "z": 1.34, "cx": 1500, "cy": 360, "ease": true, "note": "menu-and-context: the whole account menu is readable AND enough interface shows for the theme flip; held through explanation + both toggles so the camera stays calm" },
      { "t": 66.6, "z": 1.34, "cx": 1500, "cy": 360 },
      { "t": 67.6, "z": 1.0, "cx": 960, "cy": 540, "ease": true, "note": "pull wide as the Academy loads: show the whole destination" },
      { "t": 88.686, "z": 1.0, "cx": 960, "cy": 540 }
    ],
    "completion": { "text": "Account Menu — Complete", "from": 86.9, "fadeOutFrames": 10 },
