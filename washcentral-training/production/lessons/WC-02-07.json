    "queueEmpty": "(()=>{const q=document.querySelector('.ac-qstats');const e=document.querySelector('.ac-scroll:not(.ac-ctx) .ac-empty');return !!q&&/0 waiting/.test(q.textContent||'')&&!!e&&e.getBoundingClientRect().width>0&&/No matching handoffs/.test(e.textContent||'')})()",
    "sortOpen": "(()=>{const s=document.querySelector('#ac-sort');try{return !!s&&s.matches(':open')}catch(e){return false}})()",
