    "pageReady": "document.readyState==='complete'&&!!document.querySelector('.ac-grid')&&[...document.querySelectorAll('.ac-empty')].some(e=>e.getBoundingClientRect().width>0)&&(()=>{const l=document.querySelector('#page-loader');return !l||getComputedStyle(l).opacity==='0'})()",
